rr=asyncio.subprocess.PIPE,\n    53→            )\n    54→            active_process = process\n    55→\n    56→            current_tool_name = None\n    57→            current_tool_input = \"\"\n    58→            await ws.send_json({\"type\": \"start\"})\n    59→\n    60→            try:\n    61→                async for raw_line in process.stdout:\n    62→                    line = raw_line.decode().strip()\n    63→                    if not line:\n    64→                        continue\n    65→                    try:\n    66→                        event = json.loads(line)\n    67→                    except json.JSONDecodeError:\n    68→                        continue\n    69→\n    70→                    if event[\"type\"] == \"system\":\n    71→                        if event.get(\"subtype\") == \"init\":\n    72→                            if event.get(\"session_id\") and not session_id:\n    73→                                session_id = event[\"session_id\"]\n    74→                                print(f\"Session started: {session_id}\")\n    75→                            await ws.send_json({\n    76→                                \"type\": \"init\",\n    77→                                \"model\": event.get(\"model\"),\n    78→                                \"tools\": len(event.get(\"tools\", [])),\n    79→                            })\n    80→\n    81→                    elif event[\"type\"] == \"stream_event\":\n    82→                        se = event[\"event\"]\n    83→\n    84→                        if se[\"type\"] == \"content_block_start\":\n    85→                            cb = se.get(\"content_block\", {})\n    86→                            if cb.get(\"type\") == \"thinking\":\n    87→                                await ws.send_json({\"type\": \"thinking\"})\n    88→                            elif cb.get(\"type\") == \"tool_use\":\n    89→                                current_tool_name = cb.get(\"name\")\n    90→                                current_tool_input = \"\"\n    91→\n    92→                        elif se[\"type\"] == \"content_block_delta\":\n    93→                            delta = se.get(\"delta\", {})\n    94→                            if delta.get(\"type\") == \"text_delta\" and delta.get(\"text\"):\n    95→                                await ws.send_json({\"type\": \"text\", \"text\": delta[\"text\"]})\n    96→                            elif delta.get(\"type\") == \"input_json_delta\" and delta.get(\"partial_json\"):\n    97→                                current_tool_input += delta[\"partial_json\"]\n    98→\n    99→                        elif se[\"type\"] == \"content_block_stop\":\n   100→                            if current_tool_name:\n   101→                                try:\n   102→                                    inp = json.loads(current_tool_input)\n   103→                                except json.JSONDecodeError:\n   104→                                    inp = {}\n   105→                                await ws.send_json({\n   106→                                    \"type\": \"tool_use\",\n   107→                                    \"tool\": current_tool_name,\n   108→                                    \"input\": inp,\n   109→                                })\n   110→                                current_tool_name = None\n   111→                                current_tool_input = \"\"\n   112→\n   113→                    elif event[\"type\"] == \"assistant\":\n   114→                        content = event.get(\"message\", {}).get(\"content\", [])\n   115→                        for block in content:\n   116→                            if block.get(\"type\") == \"tool_use\":\n   117→                                await ws.send_json({\n   118→                                    \"type\": \"tool_use\",\n   119→                                    \"tool\": block[\"name\"],\n   120→                                    \"input\": block.get(\"input\", {}),\n   121→                                })\n   122→                            elif block.get(\"type\") == \"text\" and block.get(\"text\"):\n   123→                                if event.get(\"error\") or block[\"text\"].startswith(\"API Error\"):\n   124→                                    await ws.send_json({\"type\": \"error\", \"text\": block[\"text\"]})\n   125→\n   126→                    elif event[\"type\"] == \"result\":\n   127→                        await ws.send_json({\n   128→                            \"type\": \"result\",\n   129→                            \"text\": event.get(\"result\"),\n   130→                            \"is_error\": event.get(\"is_error\"),\n   131→                            \"duration_ms\": event.get(\"duration_ms\"),\n   132→                            \"cost_usd\": event.get(\"total_cost_usd\"),\n   133→                            \"input_tokens\": event.get(\"usage\", {}).get(\"input_tokens\"),\n   134→                            \"output_tokens\": event.get(\"usage\", {}).get(\"output_tokens\"),\n   135→                            \"cache_read_tokens\": event.get(\"usage\", {}).get(\"cache_read_input_tokens\"),\n   136→                        })\n   137→\n   138→            except Exception as e:\n   139→                await ws.send_json({\"type\": \"error\", \"text\": str(e)})\n   140→\n   141→            await process.wait()\n   142→            exit_code = process.returncode\n   143→            active_process = None\n   144→            await ws.send_json({\"type\": \"done\", \"code\": exit_code})\n   145→\n   146→    except WebSocketDisconnect:\n   147→        print(\"Client disconnected\")\n   148→        if active_process:\n   149→            active_process.kill()\n   150→\n   151→\n   152→@app.get(\"/\")\n   153→async def index():\n   154→    return FileResponse(\"public/index.html\")\n   155→\n   156→\n   157→app.mount(\"/\", StaticFiles(directory=\"public\"), name=\"static\")\n   158→\n   159→if __name__ == \"__main__\":\n   160→    import uvicorn\n   161→    uvicorn.run(app, host=\"0.0.0.0\", port=PORT)\n   162→"}]},"parent_tool_use_id":null,"session_id":"7e2b158b-d434-4ee4-90db-f84f20939677","uuid":"ab5502e9-1c84-4a7b-87ba-b56f4d3a09c9","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/summit/server.py","content":"import asyncio\nimport json\nimport os\n\nfrom fastapi import FastAPI, WebSocket, WebSocketDisconnect\nfrom fastapi.responses import FileResponse\nfrom fastapi.staticfiles import StaticFiles\n\napp = FastAPI()\n\nPORT = int(os.environ.get(\"PORT\", 3000))\n\n\n@app.websocket(\"/ws\")\nasync def websocket_endpoint(ws: WebSocket):\n    await ws.accept()\n    session_id = None\n    active_process = None\n\n    try:\n        while True:\n            data = await ws.receive_text()\n            msg = json.loads(data)\n\n            if msg.get(\"type\") != \"chat\":\n                continue\n\n            if active_process is not None:\n                await ws.send_json({\"type\": \"error\", \"text\": \"A request is already in progress.\"})\n                continue\n\n            prompt = msg[\"text\"]\n            print(f\"Received prompt: {prompt}\")\n\n            env = {k: v for k, v in os.environ.items() if k != \"CLAUDECODE\"}\n\n            cmd = [\n                \"claude\", \"-p\",\n                \"--output-format\", \"stream-json\",\n                \"--verbose\",\n                \"--include-partial-messages\",\n                \"--dangerously-skip-permissions\",\n            ]\n            if session_id:\n                cmd.extend([\"--resume\", session_id])\n            cmd.append(prompt)\n\n            process = await asyncio.create_subprocess_exec(\n                *cmd,\n                env=env,\n                stdout=asyncio.subprocess.PIPE,\n                stderr=asyncio.subprocess.PIPE,\n            )\n            active_process = process\n\n            current_tool_name = None\n            current_tool_input = \"\"\n            await ws.send_json({\"type\": \"start\"})\n\n            try:\n                async for raw_line in process.stdout:\n                    line = raw_line.decode().strip()\n                    if not line:\n                        continue\n                    try:\n                        event = json.loads(line)\n                    except json.JSONDecodeError:\n                        continue\n\n                    if event[\"type\"] == \"system\":\n                        if event.get(\"subtype\") == \"init\":\n                            if event.get(\"session_id\") and not session_id:\n                                session_id = event[\"session_id\"]\n                                print(f\"Session started: {session_id}\")\n                            await ws.send_json({\n                                \"type\": \"init\",\n                                \"model\": event.get(\"model\"),\n                                \"tools\": len(event.get(\"tools\", [])),\n                            })\n\n                    elif event[\"type\"] == \"stream_event\":\n                        se = event[\"event\"]\n\n                        if se[\"type\"] == \"content_block_start\":\n                            cb = se.get(\"content_block\", {})\n                            if cb.get(\"type\") == \"thinking\":\n                                await ws.send_json({\"type\": \"thinking\"})\n                            elif cb.get(\"type\") == \"tool_use\":\n                                current_tool_name = cb.get(\"name\")\n                                current_tool_input = \"\"\n\n                        elif se[\"type\"] == \"content_block_delta\":\n                            delta = se.get(\"delta\", {})\n                            if delta.get(\"type\") == \"text_delta\" and delta.get(\"text\"):\n                                await ws.send_json({\"type\": \"text\", \"text\": delta[\"text\"]})\n                            elif delta.get(\"type\") == \"input_json_delta\" and delta.get(\"partial_json\"):\n                                current_tool_input += delta[\"partial_json\"]\n\n                        elif se[\"type\"] == \"content_block_stop\":\n                            if current_tool_name:\n                                try:\n                                    inp = json.loads(current_tool_input)\n                                except json.JSONDecodeError:\n                                    inp = {}\n                                await ws.send_json({\n                                    \"type\": \"tool_use\",\n                                    \"tool\": current_tool_name,\n                                    \"input\": inp,\n                                })\n                                current_tool_name = None\n                                current_tool_input = \"\"\n\n                    elif event[\"type\"] == \"assistant\":\n                        content = event.get(\"message\", {}).get(\"content\", [])\n                        for block in content:\n                            if block.get(\"type\") == \"tool_use\":\n                                await ws.send_json({\n                                    \"type\": \"tool_use\",\n                                    \"tool\": block[\"name\"],\n                                    \"input\": block.get(\"input\", {}),\n                                })\n                            elif block.get(\"type\") == \"text\" and block.get(\"text\"):\n                                if event.get(\"error\") or block[\"text\"].startswith(\"API Error\"):\n                                    await ws.send_json({\"type\": \"error\", \"text\": block[\"text\"]})\n\n                    elif event[\"type\"] == \"result\":\n                        await ws.send_json({\n                            \"type\": \"result\",\n                            \"text\": event.get(\"result\"),\n                            \"is_error\": event.get(\"is_error\"),\n                            \"duration_ms\": event.get(\"duration_ms\"),\n                            \"cost_usd\": event.get(\"total_cost_usd\"),\n                            \"input_tokens\": event.get(\"usage\", {}).get(\"input_tokens\"),\n                            \"output_tokens\": event.get(\"usage\", {}).get(\"output_tokens\"),\n                            \"cache_read_tokens\": event.get(\"usage\", {}).get(\"cache_read_input_tokens\"),\n                        })\n\n            except Exception as e:\n                await ws.send_json({\"type\": \"error\", \"text\": str(e)})\n\n            await process.wait()\n            exit_code = process.returncode\n            active_process = None\n            await ws.send_json({\"type\": \"done\", \"code\": exit_code})\n\n    except WebSocketDisconnect:\n        print(\"Client disconnected\")\n        if active_process:\n            active_process.kill()\n\n\n@app.get(\"/\")\nasync def index():\n    return FileResponse(\"public/index.html\")\n\n\napp.mount(\"/\", StaticFiles(directory=\"public\"), name=\"static\")\n\nif __name__ == \"__main__\":\n    import uvicorn\n    uvicorn.run(app, host=\"0.0.0.0\", port=PORT)\n","numLines":162,"startLine":1,"totalLines":162}}}
